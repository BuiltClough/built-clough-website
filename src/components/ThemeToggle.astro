<!--
  Theme toggle pill — 36×20px track, 14px thumb.
  Visual state is purely CSS-driven via .dark .theme-toggle-track / .dark .theme-toggle-thumb
  in global.css. JS only toggles the class, saves localStorage, and syncs aria-pressed.
  querySelectorAll handles both desktop sidebar and mobile drawer instances.
-->
<button
  class="theme-toggle-btn"
  aria-label="Toggle dark mode"
  aria-pressed="false"
  style="width:44px;height:44px;display:flex;align-items:center;justify-content:center;flex-shrink:0;cursor:pointer;border:none;background:none;padding:0"
>
  <span
    class="theme-toggle-track"
    style="display:block;position:relative;width:36px;height:20px;border-radius:10px;flex-shrink:0"
  >
    <span
      class="theme-toggle-thumb"
      style="display:block;position:absolute;width:14px;height:14px;border-radius:50%;background-color:#ffffff;top:3px;left:3px"
    ></span>
  </span>
</button>

<script>
  function syncToggles() {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll<HTMLButtonElement>('.theme-toggle-btn').forEach((btn) => {
      btn.setAttribute('aria-pressed', String(isDark));
    });
  }

  document.querySelectorAll('.theme-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      syncToggles();
    });
  });

  syncToggles();
</script>
