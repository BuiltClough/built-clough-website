---
import ThemeToggle from './ThemeToggle.astro';
import { Image } from 'astro:assets';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href + '/');
}

const linkBase = 'text-[14px] font-normal px-3 py-2 rounded-[8px] transition-colors';
const active   = 'text-foreground bg-[#111111]/[0.06] dark:bg-[#f0f0f0]/[0.08]';
const inactive = 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]';

const linkClass = (href: string) => `${linkBase} ${isActive(href) ? active : inactive}`;
---

<!-- ── Top nav ─────────────────────────────────────────────────────────── -->
<header class="sticky top-0 z-50 bg-background border-b border-border">
  <div class="max-w-7xl mx-auto px-6 h-14 flex items-center gap-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 flex-shrink-0" aria-label="Built Clough home">
      <Image
        src="/images/og/built-clough-logo-woven-patch.svg"
        alt="Built Clough logo"
        width="26"
        height="26"
        class="rounded-full flex-shrink-0"
      />
      <span class="text-[15px] font-bold text-foreground tracking-tight">Built Clough</span>
    </a>

    <!-- Desktop links -->
    <nav aria-label="Main navigation" class="hidden md:flex items-center gap-1 flex-1">

      <!-- Services dropdown -->
      <div class="relative" id="services-dropdown">
        <button
          id="services-toggle"
          aria-expanded="false"
          aria-haspopup="true"
          class={`${linkBase} flex items-center gap-1.5 ${isActive('/services') ? active : inactive}`}
        >
          Services
          <svg id="services-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transition:transform 0.2s">
            <path d="M2 3.5L5 6.5L8 3.5" />
          </svg>
        </button>
        <div id="services-submenu" class="hidden absolute top-full left-0 mt-1.5 w-52 bg-background border border-border rounded-[10px] shadow-sm py-1.5 z-50">
          <a href="/services/kitchen-remodels"   class={`block px-4 py-2 text-[13px] font-normal transition-colors ${isActive('/services/kitchen-remodels')   ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]'}`}>Kitchen Remodels</a>
          <a href="/services/bathroom-remodels"  class={`block px-4 py-2 text-[13px] font-normal transition-colors ${isActive('/services/bathroom-remodels')  ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]'}`}>Bath Remodels</a>
          <a href="/services/decks-outdoor-living" class={`block px-4 py-2 text-[13px] font-normal transition-colors ${isActive('/services/decks-outdoor-living') ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]'}`}>Decks &amp; Outdoor</a>
          <a href="/services/handyman"            class={`block px-4 py-2 text-[13px] font-normal transition-colors ${isActive('/services/handyman')            ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]'}`}>Handyman Services</a>
          <a href="/services/painting"            class={`block px-4 py-2 text-[13px] font-normal transition-colors ${isActive('/services/painting')            ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]'}`}>Painting</a>
          <a href="/services/windows-doors"       class={`block px-4 py-2 text-[13px] font-normal transition-colors ${isActive('/services/windows-doors')       ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]'}`}>Windows &amp; Doors</a>
          <a href="/services/home-maintenance"    class={`block px-4 py-2 text-[13px] font-normal transition-colors ${isActive('/services/home-maintenance')    ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]'}`}>Home Maintenance</a>
          <a href="/services/aging-in-place"      class={`block px-4 py-2 text-[13px] font-normal transition-colors ${isActive('/services/aging-in-place')      ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.05]'}`}>Aging In Place</a>
        </div>
      </div>

      <a href="/gallery"   class={linkClass('/gallery')}>Gallery</a>
      <a href="/design"    class={linkClass('/design')}>Design</a>
      <a href="/pricing"   class={linkClass('/pricing')}>Pricing</a>
    </nav>

    <!-- Right side -->
    <div class="hidden md:flex items-center gap-3 ml-auto">
      <ThemeToggle />
      <a
        href="tel:+16189560808"
        class="text-[13px] font-normal text-[#6b6b6b] dark:text-[#888888] hover:text-foreground transition-colors"
      >
        (618) 956-0808
      </a>
      <button id="nav-cta" type="button" data-project-modal>Share a project</button>
    </div>

    <!-- Mobile right — call + hamburger -->
    <div class="flex md:hidden items-center gap-2 ml-auto">
      <a
        href="tel:+16189560808"
        class="text-[13px] font-medium px-3 rounded-[6px] bg-[#111111] text-white dark:bg-[#f0f0f0] dark:text-[#111111] hover:bg-[#333333] dark:hover:bg-[#dddddd] transition-colors"
        style="height:34px;display:flex;align-items:center"
      >
        Call us
      </a>
      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        style="min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;color:inherit"
      >
        <span id="icon-open" aria-hidden="true">
          <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
            <line x1="0" y1="1"  x2="18" y2="1"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            <line x1="0" y1="7"  x2="18" y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            <line x1="0" y1="13" x2="18" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </span>
        <span id="icon-close" class="hidden" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <line x1="1" y1="1"  x2="17" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            <line x1="17" y1="1" x2="1"  y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </span>
      </button>
    </div>

  </div>

  <!-- Mobile drawer -->
  <div id="mobile-drawer" class="hidden border-t border-border bg-background md:hidden">
    <nav aria-label="Mobile navigation">

      <button
        id="mobile-services-toggle"
        aria-expanded="false"
        class={`w-full flex items-center justify-center gap-2 px-6 py-4 text-[16px] font-normal border-b border-border transition-colors ${isActive('/services') ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888]'}`}
      >
        Services
        <svg id="mobile-services-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transition:transform 0.2s">
          <path d="M2 3.5L5 6.5L8 3.5" />
        </svg>
      </button>
      <div id="mobile-services-submenu" class="hidden flex-col bg-[#ebe7e2] dark:bg-[#232323] border-b border-border">
        <a href="/services/kitchen-remodels"     class={`py-3 text-[14px] font-normal text-center transition-colors ${isActive('/services/kitchen-remodels')     ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground'}`}>Kitchen Remodels</a>
        <a href="/services/bathroom-remodels"    class={`py-3 text-[14px] font-normal text-center transition-colors ${isActive('/services/bathroom-remodels')    ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground'}`}>Bath Remodels</a>
        <a href="/services/decks-outdoor-living" class={`py-3 text-[14px] font-normal text-center transition-colors ${isActive('/services/decks-outdoor-living') ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground'}`}>Decks &amp; Outdoor</a>
        <a href="/services/handyman"             class={`py-3 text-[14px] font-normal text-center transition-colors ${isActive('/services/handyman')             ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground'}`}>Handyman Services</a>
        <a href="/services/painting"             class={`py-3 text-[14px] font-normal text-center transition-colors ${isActive('/services/painting')             ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground'}`}>Painting</a>
        <a href="/services/windows-doors"        class={`py-3 text-[14px] font-normal text-center transition-colors ${isActive('/services/windows-doors')        ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground'}`}>Windows &amp; Doors</a>
        <a href="/services/home-maintenance"     class={`py-3 text-[14px] font-normal text-center transition-colors ${isActive('/services/home-maintenance')     ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground'}`}>Home Maintenance</a>
        <a href="/services/aging-in-place"       class={`py-3 text-[14px] font-normal text-center transition-colors ${isActive('/services/aging-in-place')       ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888] hover:text-foreground'}`}>Aging In Place</a>
      </div>

      <a href="/gallery"   class={`flex justify-center px-6 py-4 text-[16px] font-normal border-b border-border transition-colors ${isActive('/gallery')   ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888]'}`}>Gallery</a>
      <a href="/design"    class={`flex justify-center px-6 py-4 text-[16px] font-normal border-b border-border transition-colors ${isActive('/design')    ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888]'}`}>Design</a>
      <a href="/pricing"   class={`flex justify-center px-6 py-4 text-[16px] font-normal border-b border-border transition-colors ${isActive('/pricing')   ? 'text-foreground' : 'text-[#6b6b6b] dark:text-[#888888]'}`}>Pricing</a>

      <div class="px-6 py-6 flex flex-col items-center gap-4">
        <div class="flex items-center gap-2.5">
          <ThemeToggle />
          <span id="mobile-theme-label" class="text-[11px] font-normal text-[#999999] tracking-[0.04em]">Lights on</span>
        </div>
        <button type="button" data-project-modal class="text-[14px] font-medium px-[22px] py-[11px] rounded-[6px] bg-[#111111] text-white dark:bg-[#f0f0f0] dark:text-[#111111] w-full text-center border-none cursor-pointer">
          Share a project
        </button>
        <a href="tel:+16189560808" class="text-[13px] font-normal text-[#999999] hover:text-foreground transition-colors">
          (618) 956-0808
        </a>
      </div>
    </nav>
  </div>
</header>

<style is:global>
  #nav-cta {
    height: 34px;
    display: flex;
    align-items: center;
    font-size: 13px;
    font-weight: 500;
    padding: 0 1rem;
    border-radius: 6px;
    border: 1px solid #e0dbd4;
    color: #6b6b6b;
    background: transparent;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .dark #nav-cta {
    border-color: rgba(255, 255, 255, 0.08);
    color: #888888;
  }
  #nav-cta:hover {
    color: #111111;
    border-color: #c8c2bb;
  }
  .dark #nav-cta:hover {
    color: #f0f0f0;
    border-color: rgba(255, 255, 255, 0.16);
  }
  #nav-cta.scrolled {
    background: #111111;
    color: #ffffff;
    border-color: transparent;
  }
  .dark #nav-cta.scrolled {
    background: #f0f0f0;
    color: #111111;
    border-color: transparent;
  }
  #nav-cta.scrolled:hover {
    background: #333333;
  }
  .dark #nav-cta.scrolled:hover {
    background: #dddddd;
  }
</style>

<script>
  // Nav CTA: secondary → primary on scroll
  const navCta = document.getElementById('nav-cta');
  function updateNavCta() {
    navCta?.classList.toggle('scrolled', window.scrollY > 80);
  }
  window.addEventListener('scroll', updateNavCta, { passive: true });
  updateNavCta();

  // Theme label sync
  function syncThemeLabel() {
    const text = document.documentElement.classList.contains('dark') ? 'Lights off' : 'Lights on';
    const label = document.getElementById('mobile-theme-label');
    if (label) label.textContent = text;
  }
  syncThemeLabel();
  document.querySelectorAll('.theme-toggle-btn').forEach((btn) => {
    btn.addEventListener('click', syncThemeLabel);
  });

  // Desktop services dropdown
  const servicesToggle  = document.getElementById('services-toggle');
  const servicesSubmenu = document.getElementById('services-submenu');
  const servicesChevron = document.getElementById('services-chevron');

  servicesToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = servicesSubmenu?.classList.toggle('hidden') === false;
    servicesToggle.setAttribute('aria-expanded', String(isOpen));
    if (servicesChevron) servicesChevron.style.transform = isOpen ? 'rotate(180deg)' : '';
  });

  document.addEventListener('click', () => {
    servicesSubmenu?.classList.add('hidden');
    servicesToggle?.setAttribute('aria-expanded', 'false');
    if (servicesChevron) servicesChevron.style.transform = '';
  });

  // Mobile services accordion
  const mobileServicesToggle  = document.getElementById('mobile-services-toggle');
  const mobileServicesSubmenu = document.getElementById('mobile-services-submenu');
  const mobileServicesChevron = document.getElementById('mobile-services-chevron');

  mobileServicesToggle?.addEventListener('click', () => {
    const isOpen = mobileServicesSubmenu?.classList.toggle('hidden') === false;
    mobileServicesSubmenu?.classList.toggle('flex', isOpen);
    mobileServicesToggle.setAttribute('aria-expanded', String(isOpen));
    if (mobileServicesChevron) mobileServicesChevron.style.transform = isOpen ? 'rotate(180deg)' : '';
  });

  // Mobile hamburger
  const btn       = document.getElementById('mobile-menu-btn');
  const drawer    = document.getElementById('mobile-drawer');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = drawer?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
