---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import ParallaxHero from '../components/ParallaxHero.astro';
import ParallaxBanner from '../components/ParallaxBanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const services = [
  {
    title: 'Kitchens',
    href: '/services/kitchen-remodels',
    img: '/images/og/cherry-butcher-block-countertop-cooktop-detail.avif',
    description: 'Full remodels, cabinet refinishing, islands, countertops, and layouts that actually work for how you cook and spend time together.',
    icon: `<rect x="2" y="4" width="16" height="13" rx="1.5"/><line x1="2" y1="9.5" x2="18" y2="9.5"/><circle cx="7" cy="7" r="1.5" fill="currentColor" stroke="none"/><circle cx="13" cy="7" r="1.5" fill="currentColor" stroke="none"/><rect x="6" y="11.5" width="8" height="3.5" rx="1"/>`,
    items: [
      'Full kitchen renovations',
      'Cabinet installation & painting',
      'Countertop replacement',
      'Appliance integration',
      'Lighting & electrical upgrades',
    ],
  },
  {
    title: 'Bathrooms',
    href: '/services/bathroom-remodels',
    img: '/images/og/apple-creek-bath-remodel-01.avif',
    description: 'Walk-in showers, tub conversions, vanities, tile work, and the kind of waterproofing that keeps everything solid behind the walls.',
    icon: `<path d="M3 11h14v2a4 4 0 01-4 4H7a4 4 0 01-4-4v-2z"/><path d="M5 11V7.5a2.5 2.5 0 015 0V11"/><line x1="7.5" y1="17" x2="7" y2="19"/><line x1="12.5" y1="17" x2="13" y2="19"/>`,
    items: [
      'Walk-in shower conversions',
      'Tile & flooring installation',
      'Vanity & fixture upgrades',
      'Accessibility modifications',
      'Full gut & rebuild',
    ],
  },
  {
    title: 'Decks & Outdoor',
    href: '/services/decks-outdoor-living',
    img: '/images/og/makanda-deck-remodel.avif',
    description: 'New builds, covered porches, outdoor kitchens, and staining. We design around how you actually want to use the space, not just what fits.',
    icon: `<rect x="2" y="9" width="16" height="7" rx="1"/><path d="M2 9l8-5.5L18 9"/><line x1="6.5" y1="9" x2="6.5" y2="16"/><line x1="10" y1="9" x2="10" y2="16"/><line x1="13.5" y1="9" x2="13.5" y2="16"/>`,
    items: [
      'New deck construction',
      'Deck repairs & refinishing',
      'Pergolas & covered patios',
      'Railings & stairs',
      'Outdoor kitchens',
    ],
  },
  {
    title: 'Windows & Doors',
    href: '/services/windows-doors',
    img: '/images/og/vertical-picture-window-pine-plank-wall-detail.avif',
    description: 'Replacements, new openings, storm doors, and hardware. Properly flashed, insulated, and sealed so they perform the way they should.',
    icon: ``,
    items: [
      'Window installation & replacement',
      'Door installation & hanging',
      'Trim & casing work',
      'Weatherproofing & sealing',
      'Storm door installation',
    ],
  },
  {
    title: 'Trim & Moulding',
    href: '/services/trim-moulding',
    img: '/images/og/kitchen-remodel-tray-ceiling-carbondale.avif',
    description: 'Crown, baseboard, wainscoting, casing, and custom millwork. The finish details that make a room feel like it was thought all the way through.',
    icon: ``,
    items: [
      'Crown moulding installation',
      'Baseboards & door casing',
      'Coffered & tray ceilings',
      'Built-in shelving & millwork',
      'Paint-grade & stain-grade finishes',
    ],
  },
  {
    title: 'Handyman Services',
    href: '/services/handyman',
    img: '/images/og/large-format-porcelain-tile-bathroom-floor.avif',
    description: 'The list of things you have been meaning to get to. Fixtures, repairs, mounting, painting, and everything in between. We show up, work through it, and leave it done.',
    icon: ``,
    items: [
      'Drywall repair & patching',
      'Door & window installation',
      'Trim & molding work',
      'Fixture replacement',
      'Seasonal maintenance',
    ],
  },
];

const steps = [
  { number: '01', title: '15-minute call', description: "We talk through what you are thinking, what you have looked at, and what your timeline looks like. If we are not the right fit for your project, we will tell you on this call.", icon: `<path d="M5 4h3l1.5 3.5-1.5 1.5c1.5 2.5 3 4 5.5 5.5l1.5-1.5L18.5 14V17c0 .5-.5 1-1 1C8 18 2 12 2 5c0-.5.5-1 1-1H5z"/>` },
  { number: '02', title: 'One-hour site visit', description: "We walk the space with you, take measurements, get pictures, and talk through the options worth knowing about before any decisions get made.", icon: `<circle cx="10" cy="8" r="3"/><path d="M10 2C6.7 2 4 4.7 4 8c0 4.4 6 10 6 10s6-5.6 6-10c0-3.3-2.7-6-6-6z"/>` },
  {
    number: '03', title: 'Design & Rendering',
    description: "We build out a full 3D rendering of your project so you can see exactly what it will look like before a single thing is touched. Finishes, layout, fixtures — all of it. No guessing, no surprises.",
    icon: `<path d="M14 2l4 4-10 10H4v-4L14 2z"/><path d="M13 4l3 3"/>`,
    wide: true,
    gif: true,
  },
  { number: '04', title: 'Written proposal', description: "We send you a detailed scope with a fixed price. We want you to understand every part of it, and we will walk through it with you before you commit to anything.", icon: `<rect x="5" y="3" width="10" height="14" rx="1"/><path d="M8 3V2h4v1"/><line x1="8" y1="8" x2="12" y2="8"/><line x1="8" y1="11" x2="12" y2="11"/>`, pills: [
    { label: 'Scope of work', title: 'Scope of work', body: "A written scope of work documents exactly what we are building, materials, dimensions, finishes, and exclusions. It is the foundation of your contract. Nothing is assumed. If it is not in the scope, it is not in the price. You will have a clear record of what was agreed to before a single board is cut." },
    { label: 'Fixed price', title: 'Fixed price', body: "You get one number before we start. No hourly billing, no surprises at the end because we underestimated labor. If our estimate is off on something we should have caught, that is on us, not you. Change orders only happen when you change the scope." },
  ] },
  { number: '05', title: "Construction", description: "The people who start your project finish it. No strangers rotating through your home. We protect your space, clean up every day, and keep you informed as the work moves forward.", icon: `<circle cx="7" cy="7" r="3"/><circle cx="14" cy="7" r="3"/><path d="M1 18c0-3.3 2.7-6 6-6h6c3.3 0 6 2.7 6 6"/>`, avatars: true },
  { number: '06', title: 'Communication', description: "You can text or call any time during the build. You will hear back from one of the owners the same day.", icon: `<path d="M3 3h14c.6 0 1 .4 1 1v8c0 .6-.4 1-1 1H6l-4 3V4c0-.6.4-1 1-1z"/>`, contact: true },
  { number: '07', title: 'Final 15% held until walkthrough', description: "We do not collect the last payment until you have walked the finished space with us and told us you are happy with every detail. Punch list items get handled before we ask, not after.", icon: `<path d="M10 2L3 5.5v4.5c0 4 3 7.5 7 9 4-1.5 7-5 7-9V5.5L10 2z"/><path d="M7 10l2 2 4-4"/>`, video: true },
];

const galleryImages = [
  { src: '/images/og/white-shaker-kitchen-island-quartz-countertop-remodel.avif', alt: 'Kitchen remodel by Built Clough' },
  { src: '/images/og/freestanding-tub-board-and-batten-bathroom-remodel.avif', alt: 'Bathroom remodel by Built Clough' },
  { src: '/images/og/cathedral-pine-ceiling-three-skylights-custom-home.avif', alt: 'Custom pine cathedral ceiling by Built Clough' },
  { src: '/images/og/frameless-glass-walk-in-shower-matte-black-fixtures.avif', alt: 'Walk-in shower remodel by Built Clough' },
  { src: '/images/og/covered-deck-pine-rafter-ceiling-outdoor-living.avif', alt: 'Covered deck addition by Built Clough' },
  { src: '/images/og/master-bathroom-navy-vanity-freestanding-tub-remodel.avif', alt: 'Master bathroom remodel by Built Clough' },
  { src: '/images/og/kitchen-island-cherry-butcher-block-cooktop-remodel.avif', alt: 'Kitchen island remodel by Built Clough' },
  { src: '/images/og/double-vanity-round-mirrors-farmhouse-bathroom-remodel.avif', alt: 'Farmhouse bathroom remodel by Built Clough' },
  { src: '/images/og/board-and-batten-home-exterior-covered-porch-deck-southern-illinois.avif', alt: 'Home exterior by Built Clough' },
];


const trustChecklist = [
  { title: 'General liability insurance', detail: "Any contractor worth hiring carries it and can send it upon request." },
  { title: "Workers compensation", detail: "If someone is injured on your property during the project, you are not responsible for it." },
  { title: 'Detailed Scope of Work', detail: "A detailed scope of work and clear payment terms before any money changes hands." },
  { title: 'A Track Record You Can See', detail: "Completed projects similar to yours, and willing to put you in touch with those homeowners if you ask." },
  { title: 'A Guarantee', detail: "Any contractor you hire should stand behind their work after the job is done and make you feel confident that if something isn't right, they will take care of it." },
];

const certGrid = [
  { label: '100% insured', icon: `<circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, mobileHide: false },
  { label: "Workers' comp", icon: `<circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, mobileHide: false },
  { label: 'BBB Accredited', icon: `<circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, mobileHide: false },
  { label: 'Workmanship guarantee', icon: `<circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, mobileHide: true },
  { label: 'Marion Chamber member', icon: `<path d="M3 10l7-7 7 7v7a1 1 0 01-1 1H4a1 1 0 01-1-1v-7z" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 18v-6h6v6"/>`, mobileHide: true },
];

const projectLog = [
  { name: 'Civil War Cabin Restoration', location: 'Murphysboro, IL', date: 'Mar 2024', type: 'New build', img: '/images/og/log-cabin-exterior-metal-roof-covered-porch-southern-illinois.avif', alt: 'Civil War cabin restoration in Murphysboro, IL' },
  { name: 'Carterville Bath Remodel', location: 'Carterville, IL', date: 'Feb 2024', type: 'Bathroom', img: '/images/og/carterville-bath-remodel-01.avif', alt: 'Bathroom remodel in Carterville, IL' },
  { name: 'Makanda Kitchen Remodel', location: 'Makanda, IL', date: 'Jan 2024', type: 'Kitchen', img: '/images/og/makanda-kitchen-remodel-full.avif', alt: 'Kitchen remodel in Makanda, IL' },
];

const testimonials = [
  {
    quote: "The quality of their work really stood out, and you can tell they take pride in what they do. Our master bathroom turned out better than we imagined. The end result truly feels like something you'd find in a high-end spa. We would absolutely recommend Built Clough to anyone looking for quality work and a team you can trust.",
    name: 'Leyna D.',
    detail: 'Master bathroom remodel · 2025',
    initials: 'LD',
    avatar: '/images/og/leyna.png',
    img: '/images/og/built-clough-testimonial-03.avif',
    imgAlt: 'Master bathroom remodel by Built Clough',
    tag: 'Master Bathroom',
  },
  {
    quote: "What I love about Built Clough is that my imagination can go wild. I appreciate their ability to put life to my ideas with quality and care.",
    name: 'Terri D.',
    detail: 'Tile work & bathroom remodel · 2025',
    initials: 'TD',
    avatar: '/images/og/terri.png',
    img: '/images/og/built-clough-testimonial-02.avif',
    imgAlt: 'Bathroom tile work by Built Clough',
    tag: 'Bathroom Remodel',
  },
  {
    quote: "Built Clough far exceeded our expectations for a bathroom remodel. They worked with us in every aspect of the process and their communication was top notch. They made the whole remodel enjoyable and the finished product was exactly what I dreamed of.",
    name: 'Mellissa C.',
    detail: 'Bathroom remodel · 2025',
    initials: 'MC',
    avatar: '/images/og/mellissa.png',
    img: '/images/og/built-clough-testimonial-01.avif',
    imgAlt: 'Bathroom remodel by Built Clough',
    tag: 'Bathroom Remodel',
  },
];

const team = [
  {
    name: 'Jeff Clough',
    bio: "Jeff is your lead on the job site and the master carpenter. Over twenty years and hundreds of projects, there is not much he has not seen or figured out. He walks you through the plan, sets the standard for how the work gets done, and makes sure the finished product matches what was promised.",
    alt: 'Jeff Clough, lead carpenter at Built Clough Construction',
    img: '/images/team/jeff-clough.avif',
  },
  {
    name: 'Travis Clough',
    bio: "Travis is your designer and the person managing materials and delivery. He takes your ideas, translates them into something buildable, and makes sure everything that needs to show up does — on time and in the right order.",
    alt: 'Travis Clough, designer at Built Clough Construction',
    img: '/images/team/travis-clough.avif',
  },
  {
    name: 'Pat Clough',
    bio: "Pat is your first conversation and your main point of contact throughout the project. He handles the estimates, the proposals, and the day-to-day communication during the build. If something comes up on your project, you will hear about it from Pat before you have to ask.",
    alt: 'Pat Clough, estimator at Built Clough Construction',
    img: '/images/team/pat-clough.avif',
  },
];

const faqs = [
  { q: 'How much does a kitchen remodel cost?', a: "We'd rather talk about your specific project than throw out ranges that don't mean much. A kitchen with us could be $40k or $150k depending on size, layout changes, and finish level. The first call is free and we'll give you an honest read on whether your budget matches what you're describing." },
  { q: 'What happens if you find something behind a wall?', a: "We open the wall, take photos, and call you before we do anything else. We'll explain what we found, what it means for the project, and what the options are. You agree on a number before we do the work. Surprises behind walls are normal in remodeling, surprises on your invoice are not." },
  { q: 'How do change orders work?', a: "Same as the original estimate: line-by-line, in writing, signed before the work happens. We don't do verbal change orders. If you ask for something during the build, we'll write it up, price it, and wait for your sign-off before we start." },
  { q: 'How long does a typical project take?', a: "Kitchens usually run 6–10 weeks. Bathrooms 3–6 weeks. Decks 1–3 weeks. Additions and whole-home remodels are months, not weeks. We give you a target finish date in the proposal and update you weekly during the build." },
  { q: 'How do you protect the rest of my house during construction?', a: "Floor protection from the front door to the work area. Plastic sheeting on doorways. HVAC vents covered. Furniture moved or covered. We clean up at the end of every day and we don't leave tools out overnight where you live." },
];
---

<Layout
  title="Built Clough | Residential Construction & Remodeling in Southern Illinois"
  description="Built Clough is a family-owned residential construction and remodeling company serving Southern Illinois. Kitchens, bathrooms, decks, and more, built by three brothers for twenty years."
  canonical="https://builtclough.com"
  pageSchema={{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(({ q, a }) => ({
      "@type": "Question",
      "name": q,
      "acceptedAnswer": { "@type": "Answer", "text": a }
    }))
  }}
>

  <!-- ── Full-bleed hero ───────────────────────────────────────────────── -->
  <section class="p-4">
  <div class="parallax-banner-container relative w-full overflow-hidden rounded-[16px] flex items-center justify-center" style="min-height:90vh">
    <!-- Background image -->
    <div class="parallax-banner-img" style="position:absolute;inset:0;top:-8%;bottom:-8%;will-change:transform">
      <Image
        src="/images/og/apple-creek-bath-remodel-hero.avif"
        alt=""
        role="presentation"
        class="absolute inset-0 w-full h-full object-cover hero-zoom"
        loading="eager"
        width="1600"
        height="900"
      />
      <Image
        src="/images/og/kitchen-remodel-southern-illinois-hero-2.avif"
        alt=""
        role="presentation"
        class="absolute inset-0 w-full h-full object-cover hero-zoom hero-crossfade"
        loading="eager"
        width="1600"
        height="900"
      />
    </div>
    <!-- Overlay -->
    <div class="absolute inset-0" style="background:linear-gradient(to bottom,rgba(0,0,0,0.35) 0%,rgba(0,0,0,0.75) 100%)" aria-hidden="true"></div>
    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto w-full flex flex-col items-start justify-center text-left px-6 py-24" style="min-height:inherit">
      <!-- Avatars + stars + label -->
      <div class="flex items-center gap-3 mb-6">
        <div class="flex -space-x-2.5">
          {[
            { src: '/images/team/jeff-clough.avif', alt: 'Jeff Clough, Built Clough Construction' },
            { src: '/images/team/travis-clough.avif', alt: 'Travis Clough, Built Clough Construction' },
            { src: '/images/team/pat-clough.avif', alt: 'Pat Clough, Built Clough Construction' },
          ].map(({ src, alt }) => (
            <div class="w-8 h-8 rounded-full border-2 overflow-hidden relative flex-shrink-0" style="border-color:#ffffff;border-width:1.5px">
              <Image src={src} alt={alt} class="absolute inset-0 w-full h-full object-cover" loading="eager" width="32" height="32" />
            </div>
          ))}
        </div>
        <div class="flex flex-col gap-0.5">
          <div class="flex items-center gap-0.5" aria-label="5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg width="13" height="13" viewBox="0 0 12 12" fill="#F5A623" aria-hidden="true">
                <path d="M6 1l1.236 2.505L10 3.82l-2 1.948.472 2.752L6 7.25l-2.472 1.27L4 5.768 2 3.82l2.764-.315z" />
              </svg>
            ))}
          </div>
          <p class="text-[11px] font-normal text-white/80 uppercase tracking-[0.08em]" style="text-shadow:0 1px 4px rgba(0,0,0,0.35)">200+ Remodels / Southern Illinois</p>
        </div>
      </div>

      <h1
        class="text-[40px] md:text-[54px] leading-[1.06] font-semibold text-white tracking-[0.03em] text-balance mb-6 font-serif"
        style="max-width:20ch;text-shadow:0 1px 8px rgba(0,0,0,0.25)"
      >
        Your Home, In the Right Hands
      </h1>
      <p class="text-[17px] font-normal text-white/80 leading-[1.6] mb-10 line-clamp-2" style="max-width:44ch;text-shadow:0 1px 6px rgba(0,0,0,0.3)">
        Three brothers with twenty years of experience remodeling kitchens, bathrooms, decks, and additions in Southern Illinois. We take the time to understand what you want, work through the design with you, and build it to a standard we would want in our own home.
      </p>
      <div class="flex flex-wrap items-center justify-start gap-4 mb-10">
        <button
          type="button"
          data-project-modal
          class="text-[14px] font-medium px-[22px] rounded-[4px] bg-white text-[#111111] hover:bg-white/90 transition-colors border-none cursor-pointer"
          style="height:44px;display:flex;align-items:center"
        >
          Share your project
        </button>
        <a
          href="/gallery"
          class="text-[14px] font-medium px-[22px] rounded-[4px] border border-white/40 text-white hover:bg-white/10 transition-colors"
          style="height:44px;display:flex;align-items:center"
        >
          View our work
        </a>
      </div>

    </div>

  </div>
  <!-- Cert strip — individual tiles below hero -->
  <div class="grid grid-cols-3 md:grid-cols-5 gap-2 mt-2">
    {certGrid.map(({ label, icon, mobileHide }) => (
      <div
        class:list={['flex items-center gap-3 px-5 py-3.5 rounded-[8px] border border-border bg-[#ebe7e2] dark:bg-[#232323]', mobileHide && 'hidden md:flex']}
      >
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-foreground flex-shrink-0" set:html={icon}></svg>
        <span class="text-[12px] font-normal text-[#6b6b6b] tracking-[0.04em] uppercase leading-[1.4]">{label}</span>
      </div>
    ))}
  </div>
  </section>

  <!-- ── Intro section ────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-6 pt-10 pb-14 md:pt-16 md:pb-24">
    <div class="flex flex-col lg:flex-row lg:items-center lg:gap-16">

      <!-- Left, copy -->
      <div class="flex-1 flex flex-col items-start">
        <p class="text-[11px] font-normal text-[#999999] uppercase tracking-[0.08em] mb-5">What to expect</p>

        <h2 class="text-[32px] font-semibold text-foreground tracking-[0.03em] mb-5 font-serif">
          Know exactly what to expect before we start
        </h2>
        <p class="text-[16px] font-normal text-[#6b6b6b] leading-[1.6] mb-2 lg:mb-6" style="max-width:52ch">
          We plan it with you, price it upfront, and the same team shows up every day until the work is done. You will know who is coming, what it costs, and what to expect at every stage. We keep your space clean and organized throughout the project, and if anything changes during the build, we stop and talk to you before we go any further.
        </p>

        <!-- Two photos side by side below text, mobile only -->
        <div class="lg:hidden grid grid-cols-2 gap-2 w-full">
          <div class="relative rounded-[10px] overflow-hidden" style="aspect-ratio:4/3">
            <Image
              src="/images/og/apple-creek-bath-remodel-01.avif"
              alt="Apple Creek bathroom remodel by Built Clough"
              class="absolute inset-0 w-full h-full object-cover"
             
              width="400"
              height="300"
            />
          </div>
          <div class="relative rounded-[10px] overflow-hidden" style="aspect-ratio:4/3">
            <Image
              src="/images/og/apple-creek-bath-remodel-02.avif"
              alt="Apple Creek bathroom remodel by Built Clough"
              class="absolute inset-0 w-full h-full object-cover"
             
              width="400"
              height="300"
            />
          </div>
        </div>
      </div>

      <!-- Right, static photo -->
      <div class="mt-2 lg:mt-0 lg:flex-shrink-0 lg:w-[50%]">
        <div class="relative rounded-[12px] overflow-hidden w-full" style="aspect-ratio:1/1">
          <Image
            src="/images/og/apple-creek-bath-remodel-03.avif"
            alt="Apple Creek bathroom remodel by Built Clough"
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            width="800"
            height="800"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- ── Visual services cards ────────────────────────────────────────── -->
  <div class="animate-section">
    <div class="max-w-4xl mx-auto px-6 pb-14 md:pb-24">
      <p class="text-[11px] font-normal text-[#999999] uppercase tracking-[0.08em] mb-3">Services</p>
      <h2 class="text-[32px] font-semibold text-foreground tracking-[0.03em] mb-5 font-serif">What We Build</h2>
      <p class="text-[16px] font-normal text-[#6b6b6b] leading-[1.6] mb-6 md:mb-10" style="max-width:52ch">We do not take on more work than we can do well. That is the only reason we have stayed busy for twenty years.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border border border-border rounded-[12px] overflow-hidden">
        {services.map(({ title, description, img }) => (
          <div class="bg-[#ebe7e2] dark:bg-[#232323] p-6 flex flex-col">
            <div class="relative rounded-[12px] overflow-hidden mb-5" style="aspect-ratio:1/1">
              <Image src={img} alt={`${title} by Built Clough`} class="absolute inset-0 w-full h-full object-cover" width="400" height="400" />
            </div>
            <p class="text-[15px] font-medium text-foreground leading-snug mb-2">{title}</p>
            <p class="text-[13px] font-normal text-[#6b6b6b] leading-[1.6]">{description}</p>
          </div>
        ))}
      </div>
