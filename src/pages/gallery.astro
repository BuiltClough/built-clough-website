---

<Layout
  title="Project Gallery | Built Clough"
  description="Browse completed projects by Built Clough — kitchens, bathrooms, decks, log cabins, and finish carpentry across Southern Illinois."
  ogImage="/images/og/white-shaker-kitchen-island-quartz-countertop-remodel.avif"
  canonical="https://builtclough.com/gallery"
>
  <main id="main">

    <section class="py-14 md:py-24">
      <div class="max-w-4xl mx-auto px-6">
        <p class="text-[11px] font-normal text-[#999999] uppercase tracking-[0.08em] mb-3">Our work</p>
        <h1 class="text-[40px] font-medium text-foreground tracking-[-0.02em] mb-4" style="line-height:1.1">
          Built across Southern Illinois.
        </h1>
        <p class="text-[16px] font-normal text-[#6b6b6b] leading-[1.6]" style="max-width:52ch">
          Kitchens, bathrooms, decks, cabins, and the details that make the difference. Every project below was built by the same crew that will build yours.
        </p>
      </div>
    </section>

    <div class="max-w-4xl mx-auto px-6 pb-24">
      <div class="columns-2 md:columns-3 gap-2">
        {galleryImages.map(({ src, alt }) => (
          <div class="break-inside-avoid mb-2">
            <div class="rounded-[10px] overflow-hidden border border-border">
              <img
                src={src}
                alt={alt}
                class="w-full h-auto block"
                loading="lazy"
                width="600"
                height="400"
              />
            </div>
          </div>
        ))}
      </div>
    </div>

  </main>
</Layout>
