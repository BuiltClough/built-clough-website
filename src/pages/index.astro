          <p class="text-white/70" style="font-size:15px;line-height:1.6;margin-bottom:1.75rem">
            We don't push. We don't follow up six times. If you're ready to start, we're ready to listen.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 items-start">
            <a
              href="#"
              class="text-[14px] font-medium px-[22px] rounded-[20px] bg-white text-[#111111] hover:bg-white/90 transition-colors"
              style="height:44px;display:inline-flex;align-items:center"
            >
              Share your project
            </a>
            <a
              href="tel:+16189560808"
              class="text-[14px] font-medium px-[22px] rounded-[20px] border border-white/40 text-white hover:bg-white/10 transition-colors"
              style="height:44px;display:inline-flex;align-items:center"
            >
              (618) 956-0808
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── FAQ preview ───────────────────────────────────────────────────── -->
  <div class="animate-section">
    <section class="py-14 md:py-24">
      <div class="max-w-4xl mx-auto px-6">
        <div class="flex items-start justify-between gap-4 mb-8">
          <div>
            <p class="text-[11px] font-normal text-[#999999] uppercase tracking-[0.08em] mb-3">Common questions</p>
            <h2 class="text-[32px] font-medium text-foreground tracking-[-0.02em] mb-3">FAQ</h2>
            <p class="text-[16px] font-normal text-[#6b6b6b] leading-[1.6]" style="max-width:40ch">Straight answers to what most people ask before they hire us.</p>
          </div>
          <a href="/faq" class="text-[14px] font-normal text-[#6b6b6b] hover:text-foreground transition-colors flex-shrink-0 mt-1">
            See all questions →
          </a>
        </div>
        <FAQAccordion items={faqs} />
      </div>
    </section>
  </div>

  <!-- ── Pill modal ────────────────────────────────────────────────────── -->
  <div
    id="pill-modal"
    class="hidden fixed inset-0 z-[200] flex items-center justify-center px-6"
    role="dialog"
    aria-modal="true"
    aria-labelledby="pill-modal-title"
  >
    <!-- Backdrop -->
    <div id="pill-modal-backdrop" class="absolute inset-0 bg-[#111111]/50"></div>
    <!-- Panel -->
    <div class="relative bg-background border border-border rounded-[16px] p-8 max-w-md w-full">
      <h2 id="pill-modal-title" class="text-[20px] font-medium text-foreground tracking-[-0.02em] mb-3"></h2>
      <p id="pill-modal-body" class="text-[14px] font-normal text-[#6b6b6b] leading-[1.6]"></p>
      <button
        id="pill-modal-close"
        type="button"
        aria-label="Close"
        class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full text-[#999999] hover:text-foreground hover:bg-[#111111]/[0.06] dark:hover:bg-[#f0f0f0]/[0.08] transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <line x1="1" y1="1" x2="13" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="13" y1="1" x2="1" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

</Layout>

<script>
  const modal = document.getElementById('pill-modal')!;
  const modalTitle = document.getElementById('pill-modal-title')!;
  const modalBody = document.getElementById('pill-modal-body')!;
  const closeBtn = document.getElementById('pill-modal-close')!;
  const backdrop = document.getElementById('pill-modal-backdrop')!;

  function openModal(title: string, body: string) {
    modalTitle.textContent = title;
    modalBody.textContent = body;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.pill-modal-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      openModal(btn.dataset.title ?? '', btn.dataset.body ?? '');
    });
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
</script>
