---
import Layout from '../layouts/Layout.astro';
import ParallaxHero from '../components/ParallaxHero.astro';
import ParallaxBanner from '../components/ParallaxBanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const services = [
  {
    title: 'Kitchen remodels',
    href: '/services/kitchen-remodels',
    icon: `<rect x="2" y="4" width="16" height="13" rx="1.5"/><line x1="2" y1="9.5" x2="18" y2="9.5"/><circle cx="7" cy="7" r="1.5" fill="currentColor" stroke="none"/><circle cx="13" cy="7" r="1.5" fill="currentColor" stroke="none"/><rect x="6" y="11.5" width="8" height="3.5" rx="1"/>`,
    items: [
      'Full kitchen renovations',
      'Cabinet installation & painting',
      'Countertop replacement',
      'Appliance integration',
      'Lighting & electrical upgrades',
    ],
  },
  {
    title: 'Bathroom remodels',
    href: '/services/bathroom-remodels',
    icon: `<path d="M3 11h14v2a4 4 0 01-4 4H7a4 4 0 01-4-4v-2z"/><path d="M5 11V7.5a2.5 2.5 0 015 0V11"/><line x1="7.5" y1="17" x2="7" y2="19"/><line x1="12.5" y1="17" x2="13" y2="19"/>`,
    items: [
      'Walk-in shower conversions',
      'Tile & flooring installation',
      'Vanity & fixture upgrades',
      'Accessibility modifications',
      'Full gut & rebuild',
    ],
  },
  {
    title: 'Decks & outdoor living',
    href: '/services/decks-outdoor-living',
    icon: `<rect x="2" y="9" width="16" height="7" rx="1"/><path d="M2 9l8-5.5L18 9"/><line x1="6.5" y1="9" x2="6.5" y2="16"/><line x1="10" y1="9" x2="10" y2="16"/><line x1="13.5" y1="9" x2="13.5" y2="16"/>`,
    items: [
      'New deck construction',
      'Deck repairs & refinishing',
      'Pergolas & covered patios',
      'Railings & stairs',
      'Outdoor kitchens',
    ],
  },
  {
    title: 'Handyman services',
    href: '/services/handyman',
    icon: `<path d="M14.5 2.5a4 4 0 00-4.8 5.3L3.4 14a1.5 1.5 0 002.1 2.1l6.3-6.3a4 4 0 005.3-4.8l-2.8 2.8-1.8-1.8 2-3.5z"/>`,
    items: [
      'Drywall repair & patching',
      'Door & window installation',
      'Trim & molding work',
      'Fixture replacement',
      'Seasonal maintenance',
    ],
  },
];

const steps = [
  { number: '01', title: '15-min call', description: "We talk through what you're thinking, what you've considered, what your timeline looks like. No pressure, no upselling. If we're not the right fit, we'll tell you on this call." },
  { number: '02', title: '1-hour site visit', description: "We come walk the space, take measurements, ask the questions that matter. We point out the things in your plan that won't work and suggest the things that will." },
  {
    number: '03', title: '2–3 days to design',
    description: "We do all design work in-house. We're not interior designers — we're builders who design, which means we understand loads, mechanicals, and what your house can actually handle. We're good at finding creative solutions when budget or existing conditions get in the way.",
    wide: true,
    gif: true,
  },
  { number: '04', title: '5 days to a written proposal', description: "Line-by-line. Materials, labor, allowances, timeline. You'll know what's included and what isn't before you sign anything.", pills: [
    { label: 'Scope of work', title: 'Scope of work', body: "A written scope of work documents exactly what we're building — materials, dimensions, finishes, and exclusions. It's the foundation of your contract. Nothing is assumed; if it's not in the scope, it's not in the price. You'll have a clear record of what was agreed to before a single board is cut." },
    { label: 'Fixed price', title: 'Fixed price', body: "You get one number before we start. No hourly billing, no surprises at the end because we underestimated labor. If our estimate is off on something we should have caught, that's on us — not you. Change orders only happen when you change the scope." },
  ] },
  { number: '05', title: "Same crew, every day, until it's done", description: "No rotating subs you've never met. The people who start your project finish it.", avatars: true },
  { number: '06', title: 'Direct line to your project contact', description: "A real cell phone number, not a main office line. Text or call any time during the build — you'll hear back same day.", contact: true },
  { number: '07', title: 'Final 15% held until walkthrough', description: "We don't ask for the last payment until you've walked the finished space with us and signed off. Punch list done before we ask, not after.", video: true },
];

const galleryImages = [
  { src: '/images/og/white-shaker-kitchen-island-quartz-countertop-remodel.avif', alt: 'Kitchen remodel by Built Clough' },
  { src: '/images/og/freestanding-tub-board-and-batten-bathroom-remodel.avif', alt: 'Bathroom remodel by Built Clough' },
  { src: '/images/og/cathedral-pine-ceiling-three-skylights-custom-home.avif', alt: 'Custom pine cathedral ceiling by Built Clough' },
  { src: '/images/og/frameless-glass-walk-in-shower-matte-black-fixtures.avif', alt: 'Walk-in shower remodel by Built Clough' },
  { src: '/images/og/covered-deck-pine-rafter-ceiling-outdoor-living.avif', alt: 'Covered deck addition by Built Clough' },
  { src: '/images/og/master-bathroom-navy-vanity-freestanding-tub-remodel.avif', alt: 'Master bathroom remodel by Built Clough' },
  { src: '/images/og/kitchen-island-cherry-butcher-block-cooktop-remodel.avif', alt: 'Kitchen island remodel by Built Clough' },
  { src: '/images/og/double-vanity-round-mirrors-farmhouse-bathroom-remodel.avif', alt: 'Farmhouse bathroom remodel by Built Clough' },
  { src: '/images/og/board-and-batten-home-exterior-covered-porch-deck-southern-illinois.avif', alt: 'Home exterior by Built Clough' },
];


const trustChecklist = [
  { title: 'General liability insurance', detail: "$2M coverage. We'll send you the certificate before we start work." },
  { title: "Workers' compensation", detail: "If someone gets hurt on your property, you're not the one paying for it." },
  { title: 'Permits pulled in our name', detail: "On every job that requires them. We don't ask homeowners to pull permits to save a few dollars." },
  { title: 'A signed contract', detail: 'With detailed scope and payment terms — before any money changes hands.' },
];

const certGrid = [
  'General liability',
  "Workers' comp",
  'Permits pulled',
  'BBB Accredited',
  'Workmanship guarantee',
];

const projectLog = [
  { name: 'Marion Kitchen Remodel', location: 'Marion, IL', date: 'Oct 2024', type: 'Kitchen', img: '/images/og/white-shaker-kitchen-island-quartz-countertop-remodel.avif', alt: 'Kitchen remodel in Marion, IL' },
  { name: 'Carbondale Master Bathroom', location: 'Carbondale, IL', date: 'Aug 2024', type: 'Bathroom', img: '/images/og/master-bathroom-navy-vanity-freestanding-tub-remodel.avif', alt: 'Master bathroom remodel in Carbondale, IL' },
  { name: 'Herrin Covered Deck', location: 'Herrin, IL', date: 'Jun 2024', type: 'Deck', img: '/images/og/covered-deck-pine-rafter-ceiling-outdoor-living.avif', alt: 'Covered deck in Herrin, IL' },
  { name: 'Murphysboro Log Cabin', location: 'Murphysboro, IL', date: 'Mar 2024', type: 'New build', img: '/images/og/log-cabin-exterior-metal-roof-covered-porch-southern-illinois.avif', alt: 'Log cabin build in Murphysboro, IL' },
  { name: 'Makanda Walk-In Shower', location: 'Makanda, IL', date: 'Jan 2024', type: 'Bathroom', img: '/images/og/frameless-glass-walk-in-shower-matte-black-fixtures.avif', alt: 'Walk-in shower remodel in Makanda, IL' },
  { name: 'Carterville Kitchen & Island', location: 'Carterville, IL', date: 'Nov 2023', type: 'Kitchen', img: '/images/og/kitchen-island-cherry-butcher-block-cooktop-remodel.avif', alt: 'Kitchen remodel in Carterville, IL' },
];

const testimonials = [
  {
    quote: "Jeff and his crew redid our entire kitchen from top to bottom. They showed up every day on time, kept the site clean, and finished two days ahead of schedule. The quality is outstanding — we get compliments from everyone who visits.",
    name: 'Sarah M.',
    detail: 'Marion, IL · Kitchen remodel · 2024',
    initials: 'SM',
    img: '/images/og/white-shaker-kitchen-island-quartz-countertop-remodel.avif',
    imgAlt: 'Kitchen remodel by Built Clough in Marion, IL',
    tag: 'Marion Kitchen',
  },
  {
    quote: "We had a complicated deck project — uneven grade, tight budget, HOA restrictions — and Pat figured out a solution that worked perfectly. The deck has been standing strong for three years now.",
    name: 'Linda R.',
    detail: 'Carbondale, IL · Deck addition · 2024',
    initials: 'LR',
    img: '/images/og/covered-deck-pine-rafter-ceiling-outdoor-living.avif',
    imgAlt: 'Covered deck addition by Built Clough in Carbondale, IL',
    tag: 'Carbondale Deck',
  },
  {
    quote: "Travis transformed our master bathroom — walk-in shower, new tile, new vanity. The craftsmanship is exactly what we were hoping for. We've already recommended Built Clough to three neighbors and they've all been equally happy.",
    name: 'Rachel & Dave P.',
    detail: 'Murphysboro, IL · Bathroom remodel · 2024',
    initials: 'RP',
    img: '/images/og/master-bathroom-navy-vanity-freestanding-tub-remodel.avif',
    imgAlt: 'Master bathroom remodel by Built Clough in Murphysboro, IL',
    tag: 'Herrin Bathroom',
  },
];

const team = [
  {
    name: 'Jeff Clough',
    bio: "You'll talk to Jeff first. He runs the calls, the proposals, and the day-to-day with homeowners during the build. If something goes wrong on your project, you'll hear it from him before you have to ask.",
    alt: 'Jeff Clough, project manager at Built Clough Construction',
    img: '/images/team/jeff-clough.avif',
  },
  {
    name: 'Travis Clough',
    bio: "Travis runs the build. Twenty years of framing, structural work, and the parts of remodeling that have to be right or nothing else works. He's on every jobsite.",
    alt: 'Travis Clough, lead carpenter at Built Clough Construction',
    img: '/images/team/travis-clough.avif',
  },
  {
    name: 'Pat Clough',
    bio: "Pat handles the finish work — tile, trim, cabinets, the details that separate a remodel you tolerate from one you love. The parts you'll look at every day for the next twenty years.",
    alt: 'Pat Clough, finishing specialist at Built Clough Construction',
    img: '/images/team/pat-clough.avif',
  },
];

const faqs = [
  { q: 'How much does a kitchen remodel cost?', a: "We'd rather talk about your specific project than throw out ranges that don't mean much. A kitchen with us could be $40k or $150k depending on size, layout changes, and finish level. The first call is free and we'll give you an honest read on whether your budget matches what you're describing." },
  { q: 'What happens if you find something behind a wall?', a: "We open the wall, take photos, and call you before we do anything else. We'll explain what we found, what it means for the project, and what the options are. You agree on a number before we do the work. Surprises behind walls are normal in remodeling — surprises on your invoice are not." },
  { q: 'How do change orders work?', a: "Same as the original estimate: line-by-line, in writing, signed before the work happens. We don't do verbal change orders. If you ask for something during the build, we'll write it up, price it, and wait for your sign-off before we start." },
  { q: 'How long does a typical project take?', a: "Kitchens usually run 6–10 weeks. Bathrooms 3–6 weeks. Decks 1–3 weeks. Additions and whole-home remodels are months, not weeks. We give you a target finish date in the proposal and update you weekly during the build." },
  { q: 'Do you handle permits and inspections?', a: "Yes. We pull permits in our name on every job that requires them. We coordinate inspections directly with the inspector. You shouldn't have to think about it." },
  { q: 'How do you protect the rest of my house during construction?', a: "Floor protection from the front door to the work area. Plastic sheeting on doorways. HVAC vents covered. Furniture moved or covered. We clean up at the end of every day and we don't leave tools out overnight where you live." },
];
---

<Layout
  title="Built Clough | Residential Construction & Remodeling in Southern Illinois"
  description="Built Clough is a family-owned residential construction and remodeling company serving Southern Illinois. Kitchens, bathrooms, decks, and more — built by three brothers for twenty years."
  canonical="https://builtclough.com"
>

  <!-- ── Full-bleed hero ───────────────────────────────────────────────── -->
  <section class="p-4">
  <div class="parallax-banner-container relative w-full overflow-hidden rounded-[16px] flex items-center justify-center" style="min-height:90vh">
    <!-- Background image -->
    <div class="parallax-banner-img" style="position:absolute;inset:0;top:-8%;bottom:-8%;will-change:transform">
      <img
        src="/images/og/kitchen-remodel-tray-ceiling-carbondale.avif"
        alt=""
        role="presentation"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        width="1600"
        height="900"
      />
    </div>
    <!-- Overlay -->
    <div class="absolute inset-0" style="background:linear-gradient(to bottom,rgba(0,0,0,0.25) 0%,rgba(0,0,0,0.65) 100%)" aria-hidden="true"></div>
    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 py-24" style="max-width:800px;margin:0 auto;min-height:inherit">
      <!-- Avatars + stars + label — stacked -->
      <div class="flex flex-col items-center gap-2 mb-6">
        <div class="flex -space-x-2.5">
          {[
            { src: '/images/team/jeff-clough.avif', alt: 'Jeff Clough, Built Clough Construction' },
            { src: '/images/team/travis-clough.avif', alt: 'Travis Clough, Built Clough Construction' },
            { src: '/images/team/pat-clough.avif', alt: 'Pat Clough, Built Clough Construction' },
          ].map(({ src, alt }) => (
            <div class="w-8 h-8 rounded-full border-2 overflow-hidden relative flex-shrink-0" style="border-color:rgba(255,255,255,0.4)">
              <img src={src} alt={alt} class="absolute inset-0 w-full h-full object-cover" loading="eager" width="32" height="32" />
            </div>
          ))}
        </div>
        <div class="flex items-center gap-0.5" aria-label="5 stars">
          {Array.from({ length: 5 }).map(() => (
            <svg width="14" height="14" viewBox="0 0 12 12" fill="#c8b89a" aria-hidden="true">
              <path d="M6 1l1.236 2.505L10 3.82l-2 1.948.472 2.752L6 7.25l-2.472 1.27L4 5.768 2 3.82l2.764-.315z" />
            </svg>
          ))}
        </div>
        <p class="text-[12px] font-normal text-white/50">300+ construction projects across Southern Illinois</p>
      </div>

      <h1
        class="text-[48px] md:text-[64px] leading-[1.06] font-medium text-white tracking-[-0.03em] text-balance mb-6"
      >
        Built right, the first time.
      </h1>
      <p class="text-[17px] font-normal text-white/70 leading-[1.6] mb-10" style="max-width:40ch">
        Three brothers. Twenty years. Kitchens, bathrooms, decks, and additions built to last in Marion, Herrin, Carbondale, and beyond.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="#"
          class="text-[14px] font-medium px-[22px] rounded-[20px] bg-white text-[#111111] hover:bg-white/90 transition-colors"
          style="height:44px;display:flex;align-items:center"
        >
          Share a project
        </a>
        <a
          href="/gallery"
          class="text-[14px] font-medium px-[22px] rounded-[20px] border border-white/40 text-white hover:bg-white/10 transition-colors"
          style="height:44px;display:flex;align-items:center"
        >
          See our work
        </a>
      </div>
    </div>
  </div>
  </section>

  <!-- ── Cert strip ───────────────────────────────────────────────────── -->
  <div class="max-w-4xl mx-auto px-6 pt-12 pb-6">
    <div class="grid grid-cols-5 gap-2">
      {certGrid.map((label) => (
        <div class="border border-border rounded-[10px] bg-[#ede9e4] dark:bg-[#2a2a2a] flex items-center justify-center py-3 px-2">
          <span class="text-[10px] font-normal text-[#999999] tracking-[0.04em] uppercase text-center leading-[1.4]">
            {label}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Intro section ────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-6 pt-10 pb-14 md:pt-16 md:pb-24">
    <div class="flex flex-col lg:flex-row lg:items-center lg:gap-16">

      <!-- Left — copy -->
      <div class="flex-1 flex flex-col items-start">
        <p class="text-[11px] font-normal text-[#999999] uppercase tracking-[0.08em] mb-5">Our promise</p>

        <h2
          class="text-[42px] leading-[1.08] font-medium text-foreground tracking-[-0.03em] text-balance mb-5"
          style="max-width:18ch"
        >
          Built right, the first time.
        </h2>
        <p class="text-[17px] font-normal text-[#6b6b6b] leading-[1.6]" style="max-width:46ch">
          Three brothers. Twenty years. Kitchens, bathrooms, decks, and additions built to last in Marion, Herrin, Carbondale, and beyond.
        </p>
      </div>

      <!-- Right — static photo -->
      <div class="mt-8 lg:mt-0 lg:flex-shrink-0 lg:w-[50%]">
        <div class="relative rounded-[12px] overflow-hidden w-full" style="aspect-ratio:1/1">
          <img
            src="/images/og/white-shaker-kitchen-island-quartz-countertop-remodel.avif"
            alt="Kitchen remodel by Built Clough"
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
            width="800"
            height="800"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- ── Services grid ─────────────────────────────────────────────────── -->
  <div class="animate-section">
    <section class="py-14 md:py-24">
      <div class="max-w-4xl mx-auto px-6">
        <p class="text-[11px] font-normal text-[#999999] uppercase tracking-[0.08em] mb-3">What we build</p>
        <h2 class="text-[32px] font-medium text-foreground tracking-[-0.02em] mb-5">What we build</h2>
        <p class="text-[16px] font-normal text-[#6b6b6b] leading-[1.6] mb-6 md:mb-10" style="max-width:52ch">
          We don't take on more work than we can do well. That's the only reason we've stayed busy for twenty years.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {services.map(({ title, href, icon, items }) => (
            <div class="bg-white dark:bg-[#1f1f1f] border border-border rounded-[12px] flex flex-col">

              <!-- Icon + Title -->
              <div class="px-5 pt-5 pb-3">
                <div class="w-[60px] h-[60px] rounded-[13px] border border-border flex items-center justify-center bg-[#f7f4f0] dark:bg-[#2a2a2a] text-foreground mb-4">
                  <svg width="30" height="30" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icon}></svg>
                </div>
                <h3 class="text-[15px] font-medium text-foreground">{title}</h3>
              </div>

              <!-- Content -->
              <div class="px-5 pb-5 flex flex-col flex-1">
                <ul class="flex-1">
                  {items.map((item) => (
                    <li class="flex items-center gap-2 py-1.5 border-b border-border last:border-b-0 text-[14px] font-normal text-[#6b6b6b]">
                      <span class="w-3.5 h-3.5 border border-border rounded-[3px] flex items-center justify-center flex-shrink-0">
                        <span class="text-[9px] text-[#999999]">✓</span>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>
                <a
                  href={href}
                  class="mt-5 text-[13px] font-normal text-[#999999] hover:text-foreground transition-colors self-start"
                >
                  Learn more →
                </a>
              </div>

            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- ── Parallax banner ───────────────────────────────────────────────── -->
  <ParallaxBanner
    src="/images/og/board-and-batten-home-exterior-covered-porch-deck-southern-illinois.avif"
    alt="Board and batten home exterior built by Built Clough in Southern Illinois"
    statement="If it's not right, we do it again."
  />

  <!-- ── Process ───────────────────────────────────────────────────────── -->
  <div class="animate-section">
    <section class="py-14 md:py-24">
      <div class="max-w-4xl mx-auto px-6">
        <p class="text-[11px] font-normal text-[#999999] uppercase tracking-[0.08em] mb-3">How we work</p>
        <h2 class="text-[32px] font-medium text-foreground tracking-[-0.02em] mb-3">How we work</h2>
        <p class="text-[16px] font-normal text-[#6b6b6b] leading-[1.6] mb-6 md:mb-10" style="max-width:52ch">Seven steps from the first call to the final walkthrough — no surprises in between.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border border border-border rounded-[12px] overflow-hidden">
          {steps.map((step) => (
            <div class:list={['bg-background p-6 flex flex-col', step.wide && 'md:col-span-2']}>
              {step.wide ? (
                <>
                  <span class="block text-[11px] font-normal text-[#999999] tracking-[0.08em] uppercase mb-4">{step.number}</span>
                  <div class="flex flex-col md:flex-row gap-6 items-start">
                    <div class="flex flex-col flex-1">
                      <h3 class="text-[15px] font-medium text-foreground mb-2">{step.title}</h3>
                      <p class="text-[14px] font-normal text-[#6b6b6b] leading-[1.6]" style="max-width:44ch">{step.description}</p>
                    </div>
                    {step.gif && (
                      <div class="w-full md:flex-1 rounded-[10px] overflow-hidden border border-border bg-[#ede9e4] dark:bg-[#2a2a2a] flex items-center justify-center" style="aspect-ratio:16/9">
                        <div class="flex flex-col items-center gap-1.5 text-[#999999]">
                          <svg width="22" height="22" viewBox="0 0 32 32" fill="none" aria-hidden="true">
                            <rect x="2" y="2" width="28" height="28" rx="4" stroke="currentColor" stroke-width="1.25" />
                            <path d="M10 16h4v4h-4v-4zm0 0v-2a6 6 0 0 1 12 0v2" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
                          </svg>
                          <span class="text-[9px] font-normal tracking-[0.04em] uppercase text-center px-2">GIF placeholder</span>
                        </div>
                      </div>
                    )}
                  </div>
                </>
              ) : (
                <>
                  <span class="block text-[11px] font-normal text-[#999999] tracking-[0.08em] uppercase mb-4">{step.number}</span>
                  <h3 class="text-[15px] font-medium text-foreground mb-2">{step.title}</h3>
                  <p class="text-[14px] font-normal text-[#6b6b6b] leading-[1.6]" style="max-width:34ch">{step.description}</p>
                </>
              )}
              {step.pills && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {step.pills.map((pill: { label: string; title: string; body: string }) => (
                    <button
                      class="pill-modal-btn inline-flex items-center px-3 py-1 rounded-full border border-[#c8c3bc] dark:border-[#555555] text-[12px] font-normal text-[#444444] dark:text-[#bbbbbb] hover:border-foreground hover:text-foreground hover:bg-[#111111]/[0.04] dark:hover:bg-[#f0f0f0]/[0.06] transition-colors cursor-pointer"
                      data-title={pill.title}
                      data-body={pill.body}
                      type="button"
                    >
                      {pill.label}
                    </button>
                  ))}
                </div>
              )}
              {step.avatars && (
                <div class="mt-auto pt-4 flex items-center gap-3">
                  <div class="flex -space-x-2.5">
                    {[
                      { src: '/images/team/jeff-clough.avif', alt: 'Jeff Clough, Built Clough' },
                      { src: '/images/team/travis-clough.avif', alt: 'Travis Clough, Built Clough' },
                      { src: '/images/team/pat-clough.avif', alt: 'Pat Clough, Built Clough' },
                    ].map(({ src, alt }) => (
