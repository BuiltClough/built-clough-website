<style>
  /* ── Testimonial masonry ───────────────────────────────────────────── */
  .testimonial-masonry {
    columns: 1;
    column-gap: 16px;
  }
  @media (min-width: 640px) {
    .testimonial-masonry { columns: 2; }
  }
  @media (min-width: 900px) {
    .testimonial-masonry { columns: 3; }
  }
  .testimonial-card {
    break-inside: avoid;
    margin-bottom: 16px;
  }

  /* ── Step panel ────────────────────────────────────────────────────── */
  .step-panel { transition: opacity 0.15s ease; }
  .step-sub {
    font-size: 13px;
    font-weight: 400;
    color: #6b6b6b;
    line-height: 1.5;
    margin-bottom: 20px;
  }
  .dark .step-sub { color: #888; }

  /* ── Step footer (back | counter | next) ──────────────────────────── */
  .step-footer {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }
  .step-footer > :last-child { justify-self: end; }
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    font-weight: 400;
    color: #6b6b6b;
    cursor: pointer;
    transition: color 0.15s;
    visibility: hidden;
  }
  .back-btn:hover { color: #111111; }
  .back-btn.visible { visibility: visible; }
  .dark .back-btn:hover { color: #f0f0f0; }

  /* ── Next / submit button ──────────────────────────────────────────── */
  .step-next-btn {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 22px;
    border-radius: 8px;
    background: #111111;
    color: #ffffff;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }
  .step-next-btn:hover { background: #222222; }
  .dark .step-next-btn { background: #f0f0f0; color: #111111; }
  .dark .step-next-btn:hover { background: #e0e0e0; }

  /* ── Render crossfade (process step 03) ───────────────────────────── */
  .render-crossfade {
    animation: render-cf 3s ease-in-out infinite alternate;
  }
  .render-crossfade-inv {
    animation: render-cf 3s ease-in-out infinite alternate-reverse;
  }
  @keyframes render-cf {
    0%,  33% { opacity: 1 }
    60%, 100% { opacity: 0 }
  }

  /* ── Radio pills ───────────────────────────────────────────────────── */
  .pill-option span {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid #d4cfc9;
    font-size: 14px;
    font-weight: 400;
    color: #444;
    cursor: pointer;
    transition: all 0.15s;
    background: #f9f7f5;
    white-space: nowrap;
  }
  .pill-option input:checked + span { background: #111111; border-color: #111111; color: #ffffff; }
  .pill-option:hover span { border-color: #111111; }
  .dark .pill-option span { background: #2a2a2a; border-color: #444; color: #ccc; }
  .dark .pill-option input:checked + span { background: #f0f0f0; border-color: #f0f0f0; color: #111; }

</style>

<script>
  var TOTAL = 6;
  var step = 1;
  var answers = { project: '', scope: '', budget: '', timeline: '', notes: '', name: '', phone: '', location: '' };

  function goTo(n) {
    var leaving = document.querySelector('[data-step="' + step + '"]');
    var entering = document.querySelector('[data-step="' + n + '"]');
    if (!entering) return;

    if (leaving) {
      leaving.style.opacity = '0';
      setTimeout(function () {
        leaving.style.display = 'none';
        entering.style.display = 'block';
        entering.style.opacity = '0';
        requestAnimationFrame(function () { entering.style.opacity = '1'; });
      }, 150);
    } else {
      entering.style.display = 'block';
      entering.style.opacity = '1';
    }

    step = n;
    updateProgress();
  }

  function updateProgress() {
    document.querySelectorAll('.back-btn').forEach(function (btn) {
      if (step === 1) btn.classList.remove('visible');
      else btn.classList.add('visible');
    });
    document.querySelectorAll('.step-counter').forEach(function (el) {
      el.textContent = step + ' of ' + TOTAL;
    });
  }

  function syncAndSubmit() {
    var nameEl = document.getElementById('name-input');
    var phoneEl = document.getElementById('phone-input');
    var locationEl = document.getElementById('location-input');
    answers.name = nameEl ? nameEl.value.trim() : '';
    answers.phone = phoneEl ? phoneEl.value.trim() : '';
    answers.location = locationEl ? locationEl.value.trim() : '';

    var valid = true;
    if (!answers.name) { if (nameEl) nameEl.style.borderColor = '#e53e3e'; valid = false; }
    if (!answers.phone) { if (phoneEl) phoneEl.style.borderColor = '#e53e3e'; valid = false; }
    if (!valid) return;

    ['project', 'scope', 'budget', 'timeline', 'notes', 'name', 'phone', 'location'].forEach(function (key) {
      var el = document.getElementById('h-' + key);
      if (el) el.value = answers[key];
    });

    var form = document.getElementById('netlify-form');
    if (form) form.submit();
  }

  // Step 1: project type (auto-advance)
  document.querySelectorAll('[name="ui-project"]').forEach(function (input) {
    input.addEventListener('change', function (e) {
      answers.project = e.target.value;
      setTimeout(function () { goTo(2); }, 220);
    });
  });

  // Step 2: scope (auto-advance)
  document.querySelectorAll('[name="ui-scope"]').forEach(function (input) {
    input.addEventListener('change', function (e) {
      answers.scope = e.target.value;
      setTimeout(function () { goTo(3); }, 220);
    });
  });

  // Step 3: budget (auto-advance)
  document.querySelectorAll('[name="ui-budget"]').forEach(function (input) {
    input.addEventListener('change', function (e) {
      answers.budget = e.target.value;
      setTimeout(function () { goTo(4); }, 220);
    });
  });

  // Step 4: timeline (auto-advance)
  document.querySelectorAll('[name="ui-timeline"]').forEach(function (input) {
    input.addEventListener('change', function (e) {
      answers.timeline = e.target.value;
      setTimeout(function () { goTo(5); }, 220);
    });
  });

  // Step 5: notes
  var step5Next = document.getElementById('step5-next');
  var step5Skip = document.getElementById('step5-skip');
  if (step5Next) step5Next.addEventListener('click', function () {
    var el = document.getElementById('notes-input');
    answers.notes = el ? el.value.trim() : '';
    goTo(6);
  });
  if (step5Skip) step5Skip.addEventListener('click', function () {
    answers.notes = '';
    goTo(6);
  });

  // Step 6: submit
  var submitBtn = document.getElementById('submit-btn');
  if (submitBtn) submitBtn.addEventListener('click', syncAndSubmit);

  // Back buttons (one per step panel)
  document.querySelectorAll('.back-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (step > 1) goTo(step - 1);
    });
  });

  // Clear red border on focus
  ['name-input', 'phone-input', 'location-input'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('focus', function () { el.style.borderColor = ''; });
  });

  // Init
  updateProgress();
</script>

<script>
  const modal = document.getElementById('pill-modal')!;
  const modalTitle = document.getElementById('pill-modal-title')!;
  const modalBody = document.getElementById('pill-modal-body')!;
  const closeBtn = document.getElementById('pill-modal-close')!;
  const backdrop = document.getElementById('pill-modal-backdrop')!;

  function openModal(title: string, body: string) {
    modalTitle.textContent = title;
    modalBody.textContent = body;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.pill-modal-btn').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn.dataset.title ?? '', btn.dataset.body ?? ''));
  });
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
</script>
