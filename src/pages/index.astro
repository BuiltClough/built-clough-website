<script>
  // Services accordion
  const servicesBtn = document.getElementById('services-accordion-btn')!;
  const servicesPanel = document.getElementById('services-accordion-panel')!;
  const servicesChevron = document.getElementById('services-accordion-chevron')!;
  servicesBtn.addEventListener('click', () => {
    const open = servicesPanel.classList.toggle('hidden') === false;
    servicesBtn.setAttribute('aria-expanded', String(open));
    servicesChevron.style.transform = open ? 'rotate(180deg)' : '';
  });

  const modal = document.getElementById('pill-modal')!;
  const modalTitle = document.getElementById('pill-modal-title')!;
  const modalBody = document.getElementById('pill-modal-body')!;
  const closeBtn = document.getElementById('pill-modal-close')!;
  const backdrop = document.getElementById('pill-modal-backdrop')!;

  function openModal(title: string, body: string) {
    modalTitle.textContent = title;
    modalBody.textContent = body;
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.pill-modal-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      openModal(btn.dataset.title ?? '', btn.dataset.body ?? '');
    });
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
</script>
