---
import LandingLayout from '../layouts/LandingLayout.astro';
import { Image } from 'astro:assets';

const steps = [
  { number: '01', title: '15-minute call', description: "We talk through what you are thinking, what you have looked at, and what your timeline looks like. If we are not the right fit for your project, we will tell you on this call.", icon: `<path d="M5 4h3l1.5 3.5-1.5 1.5c1.5 2.5 3 4 5.5 5.5l1.5-1.5L18.5 14V17c0 .5-.5 1-1 1C8 18 2 12 2 5c0-.5.5-1 1-1H5z"/>` },
  { number: '02', title: 'One-hour site visit', description: "We walk the space with you, take measurements, get pictures, and talk through the options worth knowing about before any decisions get made.", icon: `<circle cx="10" cy="8" r="3"/><path d="M10 2C6.7 2 4 4.7 4 8c0 4.4 6 10 6 10s6-5.6 6-10c0-3.3-2.7-6-6-6z"/>` },
  {
    number: '03', title: 'Design',
    description: "After the visit, we take everything we learned and put together a set of solutions that reflect what you told us you wanted. As builders, we understand how the structure, plumbing, and electrical in your home affect what is actually possible, so we present options that are real, not just ideas on paper.",
    icon: `<path d="M14 2l4 4-10 10H4v-4L14 2z"/><path d="M13 4l3 3"/>`,
    wide: true,
    gif: true,
  },
  { number: '04', title: 'Written proposal', description: "We send you a detailed scope with a fixed price. We want you to understand every part of it, and we will walk through it with you before you commit to anything.", icon: `<rect x="5" y="3" width="10" height="14" rx="1"/><path d="M8 3V2h4v1"/><line x1="8" y1="8" x2="12" y2="8"/><line x1="8" y1="11" x2="12" y2="11"/>`, pills: [
    { label: 'Scope of work', title: 'Scope of work', body: "A written scope of work documents exactly what we are building, materials, dimensions, finishes, and exclusions. It is the foundation of your contract. Nothing is assumed. If it is not in the scope, it is not in the price. You will have a clear record of what was agreed to before a single board is cut." },
    { label: 'Fixed price', title: 'Fixed price', body: "You get one number before we start. No hourly billing, no surprises at the end because we underestimated labor. If our estimate is off on something we should have caught, that is on us, not you. Change orders only happen when you change the scope." },
  ] },
  { number: '05', title: "Construction", description: "The people who start your project finish it. No strangers rotating through your home. We protect your space, clean up every day, and keep you informed as the work moves forward.", icon: `<circle cx="7" cy="7" r="3"/><circle cx="14" cy="7" r="3"/><path d="M1 18c0-3.3 2.7-6 6-6h6c3.3 0 6 2.7 6 6"/>`, avatars: true },
  { number: '06', title: 'Communication', description: "You can text or call any time during the build. You will hear back from one of the owners the same day.", icon: `<path d="M3 3h14c.6 0 1 .4 1 1v8c0 .6-.4 1-1 1H6l-4 3V4c0-.6.4-1 1-1z"/>`, contact: true },
  { number: '07', title: 'Final 15% held until walkthrough', description: "We do not collect the last payment until you have walked the finished space with us and told us you are happy with every detail. Punch list items get handled before we ask, not after.", icon: `<path d="M10 2L3 5.5v4.5c0 4 3 7.5 7 9 4-1.5 7-5 7-9V5.5L10 2z"/><path d="M7 10l2 2 4-4"/>`, video: true },
];

const certGrid = [
  { label: '100% insured', icon: `<circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, mobileHide: false },
  { label: "Workers' comp", icon: `<circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, mobileHide: false },
  { label: 'BBB Accredited', icon: `<circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, mobileHide: false },
  { label: 'Workmanship guarantee', icon: `<circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, mobileHide: true },
  { label: 'Marion Chamber member', icon: `<path d="M3 10l7-7 7 7v7a1 1 0 01-1 1H4a1 1 0 01-1-1v-7z" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 18v-6h6v6"/>`, mobileHide: true },
];
---

<LandingLayout
  title="Built Clough | Residential Construction & Remodeling in Southern Illinois"
  description="Family-owned construction and remodeling company serving Southern Illinois. Kitchens, bathrooms, decks, and more. 200+ projects completed. Get started today."
  canonical="https://builtclough.com/"
  noIndex={false}
>

  <!-- ── Hero + form ──────────────────────────────────────────────────── -->
  <section class="p-4 bg-background">
  <div class="relative overflow-hidden rounded-[16px] flex items-center justify-center">

    <!-- Header inside the rounded container -->
    <header class="absolute top-0 left-0 right-0 z-20 px-6 py-5">
      <a href="/" class="flex items-center gap-2" aria-label="Built Clough home">
        <Image
          src="/images/og/built-clough-logo-woven-patch.svg"
          alt="Built Clough logo"
          width="28"
          height="28"
          class="rounded-full flex-shrink-0"
        />
        <span class="text-white font-bold text-[16px] tracking-tight">Built Clough, LLC</span>
      </a>
    </header>

    <!-- Background image -->
    <div class="absolute inset-0">
      <Image
        src="/images/og/apple-creek-bath-remodel-hero.avif"
        alt="Bathroom remodel by Built Clough"
        class="w-full h-full object-cover"
        loading="eager"
        width="1600"
        height="1000"
      />
      <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.58) 60%, rgba(0,0,0,0.72) 100%)" aria-hidden="true"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-xl mx-auto px-6 pt-28 pb-16 flex flex-col items-center text-center">

      <!-- Avatars + social proof -->
      <div class="flex items-center gap-3 mb-6">
        <div class="flex -space-x-2.5">
          {[
            { src: '/images/team/jeff-clough.avif', alt: 'Jeff Clough' },
            { src: '/images/team/travis-clough.avif', alt: 'Travis Clough' },
            { src: '/images/team/pat-clough.avif', alt: 'Pat Clough' },
          ].map(({ src, alt }) => (
            <div class="w-9 h-9 rounded-full border-2 overflow-hidden relative flex-shrink-0" style="border-color:#ffffff">
              <Image src={src} alt={alt} class="absolute inset-0 w-full h-full object-cover" loading="eager" width="36" height="36" />
            </div>
          ))}
        </div>
        <div>
          <div class="flex items-center gap-0.5 mb-0.5">
            {Array.from({ length: 5 }).map(() => (
              <svg width="12" height="12" viewBox="0 0 12 12" fill="#F5A623" aria-hidden="true">
                <path d="M6 1l1.236 2.505L10 3.82l-2 1.948.472 2.752L6 7.25l-2.472 1.27L4 5.768 2 3.82l2.764-.315z" />
              </svg>
            ))}
          </div>
          <p class="text-[12px] font-normal text-white/60">200+ remodels across Southern Illinois</p>
        </div>
      </div>

      <h1 class="text-[36px] md:text-[48px] font-semibold text-white leading-[1.06] tracking-[-0.01em] mb-16 font-serif">
        Kitchens and Baths<br>Done the Right Way.
      </h1>

      <!-- ── Form card ────────────────────────────────────────────────── -->
      <div class="w-full">
        <div class="bg-white dark:bg-[#1a1a1a] rounded-[16px] p-7 border border-white/10">

          <!-- ── Step panels ─────────────────────────────────────────── -->

          <!-- Step 1 -->
          <div data-step="1" class="step-panel">
            <p class="text-[20px] font-medium text-[#111111] dark:text-[#f0f0f0] leading-[1.3] mb-1">What are you thinking about?</p>
            <p class="step-sub">This helps us understand the project before we meet.</p>
            <div class="flex flex-wrap justify-center gap-2 mb-7">
              {['Kitchen', 'Bathroom', 'Both'].map((opt) => (
                <label class="pill-option">
                  <input type="radio" name="ui-project" value={opt} class="sr-only" />
                  <span>{opt}</span>
                </label>
              ))}
            </div>
            <div class="step-footer">
              <button class="back-btn" type="button" aria-label="Go back">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              <span class="step-counter text-[11px] font-normal text-[#999]">1 of 6</span>
              <div></div>
            </div>
          </div>

          <!-- Step 2 -->
          <div data-step="2" class="step-panel" style="display:none">
            <p class="text-[20px] font-medium text-[#111111] dark:text-[#f0f0f0] leading-[1.3] mb-1">How would you describe the project?</p>
            <p class="step-sub">Every project is different. This helps us come prepared.</p>
            <div class="flex flex-wrap justify-center gap-2 mb-7">
              {['Refresh the space with new surfaces and fixtures', 'Change the layout or reconfigure the room', 'Not sure yet and that is okay'].map((opt) => (
                <label class="pill-option">
                  <input type="radio" name="ui-scope" value={opt} class="sr-only" />
                  <span>{opt}</span>
                </label>
              ))}
            </div>
            <div class="step-footer">
              <button class="back-btn" type="button" aria-label="Go back">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              <span class="step-counter text-[11px] font-normal text-[#999]">1 of 6</span>
              <div></div>
            </div>
          </div>

          <!-- Step 3 -->
          <div data-step="3" class="step-panel" style="display:none">
            <p class="text-[20px] font-medium text-[#111111] dark:text-[#f0f0f0] leading-[1.3] mb-1">Do you have a budget range in mind?</p>
            <p class="step-sub">This helps us design around your investment.</p>
            <div class="flex flex-wrap justify-center gap-2 mb-7">
              {['Under $20k', '$20k to $40k', '$40k to $60k', '$60k+', 'I would like some guidance'].map((opt) => (
                <label class="pill-option">
                  <input type="radio" name="ui-budget" value={opt} class="sr-only" />
                  <span>{opt}</span>
                </label>
              ))}
            </div>
            <div class="step-footer">
              <button class="back-btn" type="button" aria-label="Go back">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              <span class="step-counter text-[11px] font-normal text-[#999]">1 of 6</span>
              <div></div>
            </div>
          </div>

          <!-- Step 4 -->
          <div data-step="4" class="step-panel" style="display:none">
            <p class="text-[20px] font-medium text-[#111111] dark:text-[#f0f0f0] leading-[1.3] mb-1">When are you hoping to get started?</p>
            <p class="step-sub">If our schedule does not line up, we will tell you upfront.</p>
            <div class="flex flex-wrap justify-center gap-2 mb-7">
              {['As soon as possible', 'In the next 3 to 6 months', 'Just starting to look into it'].map((opt) => (
                <label class="pill-option">
                  <input type="radio" name="ui-timeline" value={opt} class="sr-only" />
                  <span>{opt}</span>
                </label>
              ))}
            </div>
            <div class="step-footer">
              <button class="back-btn" type="button" aria-label="Go back">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              <span class="step-counter text-[11px] font-normal text-[#999]">1 of 6</span>
              <div></div>
            </div>
          </div>

          <!-- Step 5 -->
          <div data-step="5" class="step-panel" style="display:none">
            <p class="text-[20px] font-medium text-[#111111] dark:text-[#f0f0f0] leading-[1.3] mb-1">Anything else that would help us understand your project?</p>
            <p class="step-sub">Optional. Something that has been bothering you about the space, a feature you want, or any concerns. Whatever is on your mind.</p>
            <textarea
              id="notes-input"
              rows="4"
              placeholder="Type here..."
              class="w-full px-4 py-3 rounded-[8px] border border-[#e0dbd4] dark:border-[#333] bg-[#f9f7f5] dark:bg-[#222] text-[14px] text-[#111111] dark:text-[#f0f0f0] placeholder:text-[#999] focus:outline-none focus:border-[#111] dark:focus:border-[#888] transition-colors resize-none mb-7"
            ></textarea>
            <div class="step-footer">
              <button class="back-btn" type="button" aria-label="Go back">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              <span class="step-counter text-[11px] font-normal text-[#999]">1 of 6</span>
              <div class="flex items-center gap-3">
                <button id="step5-skip" type="button" class="text-[13px] font-normal text-[#999] hover:text-[#6b6b6b] transition-colors">Skip</button>
                <button id="step5-next" type="button" class="step-next-btn">Next →</button>
              </div>
            </div>
          </div>

          <!-- Step 6 -->
          <div data-step="6" class="step-panel" style="display:none">
            <p class="text-[20px] font-medium text-[#111111] dark:text-[#f0f0f0] leading-[1.3] mb-1">How do we reach you?</p>
            <p class="step-sub">One of us will call you directly. Jeff, Travis, or Pat. No call center, no sales pitch.</p>
            <div class="flex flex-col gap-3 mb-3 mt-5">
              <input
                id="name-input"
                type="text"
                placeholder="Your name"
                autocomplete="name"
                class="w-full px-4 h-[44px] rounded-[8px] border border-[#e0dbd4] dark:border-[#333] bg-[#f9f7f5] dark:bg-[#222] text-[14px] text-[#111111] dark:text-[#f0f0f0] placeholder:text-[#999] focus:outline-none focus:border-[#111] dark:focus:border-[#888] transition-colors"
              />
              <input
                id="phone-input"
                type="tel"
                placeholder="Phone number"
                autocomplete="tel"
                class="w-full px-4 h-[44px] rounded-[8px] border border-[#e0dbd4] dark:border-[#333] bg-[#f9f7f5] dark:bg-[#222] text-[14px] text-[#111111] dark:text-[#f0f0f0] placeholder:text-[#999] focus:outline-none focus:border-[#111] dark:focus:border-[#888] transition-colors"
              />
              <input
                id="location-input"
                type="text"
                placeholder="City or town"
                autocomplete="address-level2"
                class="w-full px-4 h-[44px] rounded-[8px] border border-[#e0dbd4] dark:border-[#333] bg-[#f9f7f5] dark:bg-[#222] text-[14px] text-[#111111] dark:text-[#f0f0f0] placeholder:text-[#999] focus:outline-none focus:border-[#111] dark:focus:border-[#888] transition-colors"
              />
            </div>
            <p class="text-[11px] font-normal text-[#999] text-center leading-[1.5] mb-6">
              Your information stays with us. One call, then we come to you.
            </p>
            <div class="step-footer">
              <button class="back-btn" type="button" aria-label="Go back">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              <span class="step-counter text-[11px] font-normal text-[#999]">1 of 6</span>
              <button id="submit-btn" type="button" class="step-next-btn">Send my details</button>
            </div>
          </div>

          <!-- ── Hidden Netlify form (detected at build time) ──────── -->
          <form
            id="netlify-form"
            name="start-project"
            method="POST"
            action="/thank-you"
            data-netlify="true"
            netlify-honeypot="bot-field"
            style="display:none"
          >
            <input type="hidden" name="form-name" value="start-project" />
            <input type="hidden" name="bot-field" />
            <input type="hidden" name="project" id="h-project" />
            <input type="hidden" name="scope" id="h-scope" />
            <input type="hidden" name="budget" id="h-budget" />
            <input type="hidden" name="timeline" id="h-timeline" />
            <input type="hidden" name="notes" id="h-notes" />
            <input type="hidden" name="name" id="h-name" />
            <input type="hidden" name="phone" id="h-phone" />
            <input type="hidden" name="location" id="h-location" />
          </form>


        </div>
      </div>

    </div>
  </div>

  <!-- 2×2 photo grid -->
  <div class="max-w-4xl mx-auto px-6 w-full mt-2">
    <div class="grid grid-cols-2 gap-3">
      {[
        { src: '/images/og/white-shaker-kitchen-island-quartz-countertop-remodel.avif', alt: 'Kitchen remodel by Built Clough' },
        { src: '/images/og/master-bathroom-navy-vanity-freestanding-tub-remodel.avif', alt: 'Master bathroom remodel by Built Clough' },
        { src: '/images/og/frameless-glass-walk-in-shower-matte-black-fixtures.avif', alt: 'Walk-in shower remodel by Built Clough' },
        { src: '/images/og/freestanding-tub-board-and-batten-bathroom-remodel.avif', alt: 'Freestanding tub bathroom remodel by Built Clough' },
      ].map(({ src, alt }) => (
        <div class="relative rounded-[8px] overflow-hidden border border-border" style="aspect-ratio:1/1">
          <Image src={src} alt={alt} class="absolute inset-0 w-full h-full object-cover" width="600" height="450" />
        </div>
      ))}
    </div>
  </div>

  </section>

  <!-- ── Social proof below fold ──────────────────────────────────────── -->
  <section class="bg-[#ebe7e2] dark:bg-[#1a1a1a] py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-6">

      <!-- ── Before & After (1 of 2) ───────────────────────────────────── -->
      <p class="text-[11px] font-normal text-[#999999] uppercase tracking-[0.08em] mb-3">Before &amp; After</p>
      <h2 class="text-[32px] font-semibold text-foreground tracking-[0.03em] mb-3 font-serif">See the Work</h2>
      <p class="text-[16px] font-normal text-[#6b6b6b] leading-[1.6] mb-6" style="max-width:52ch">Every project starts somewhere.</p>
      <div class="relative w-full rounded-[12px] overflow-hidden border border-border mb-10" style="aspect-ratio:16/7">
        <Image src="/images/og/remodel-before-02.avif" alt="Before remodel by Built Clough" class="absolute inset-0 w-full h-full object-cover" width="1200" height="525" />
        <Image src="/images/og/remodel-after-02.avif" alt="After remodel by Built Clough" class="absolute inset-0 w-full h-full object-cover render-crossfade" width="1200" height="525" />
        <span class="absolute bottom-3 left-3 px-2.5 py-1 rounded-full border text-white text-[12px] font-normal tracking-[0.02em] render-crossfade-inv" style="background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.25);backdrop-filter:blur(6px)">Before</span>
        <span class="absolute bottom-3 left-3 px-2.5 py-1 rounded-full border text-white text-[12px] font-normal tracking-[0.02em] render-crossfade" style="background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.25);backdrop-filter:blur(6px)">After</span>
      </div>

      <!-- Col 1: Terri, Nic — Col 2 (center): Leyna (longest), Kendra — Col 3: Melissa, Kelsey -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-start mb-16">

        <!-- Column 1 -->
        <div class="flex flex-col gap-4">
          <div class="bg-white dark:bg-[#1f1f1f] border border-border rounded-[12px] flex flex-col">
            <div class="p-3">
              <div class="relative rounded-[8px] overflow-hidden" style="aspect-ratio:16/9">
                <Image src="/images/og/built-clough-testimonial-02.avif" alt="Bathroom tile work by Built Clough" class="absolute inset-0 w-full h-full object-cover" width="400" height="225" />
                <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,0,0,0.60) 0%,rgba(0,0,0,0.15) 50%,transparent 100%)" aria-hidden="true"></div>
                <span class="absolute bottom-3 left-3 px-2.5 py-1 rounded-full border text-white text-[12px] font-normal tracking-[0.02em]" style="background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.25);backdrop-filter:blur(6px)">Bathroom Remodel</span>
              </div>
            </div>
            <div class="px-5 pb-5 flex flex-col flex-1">
              <div class="flex items-center gap-0.5 mb-3">{Array.from({length:5}).map(()=><svg width="13" height="13" viewBox="0 0 12 12" fill="#F5A623" aria-hidden="true"><path d="M6 1l1.236 2.505L10 3.82l-2 1.948.472 2.752L6 7.25l-2.472 1.27L4 5.768 2 3.82l2.764-.315z"/></svg>)}</div>
              <p class="text-[15px] font-normal text-foreground leading-[1.65] flex-1">What I love about Built Clough is that my imagination can go wild. I appreciate their ability to put life to my ideas with quality and care. Thank you Built Clough!</p>
              <div class="flex items-center gap-3 mt-5 pt-4 border-t border-border">
                <div class="w-9 h-9 rounded-full overflow-hidden border border-border flex-shrink-0"><Image src="/images/og/terri.png" alt="Terri Douglas" class="w-full h-full object-cover" width="36" height="36" /></div>
                <div><p class="text-[13px] font-medium text-foreground">Terri D.</p><p class="text-[12px] font-normal text-[#999]">Bathroom remodel · 2025</p></div>
              </div>
            </div>
          </div>
          <div class="bg-white dark:bg-[#1f1f1f] border border-border rounded-[12px] px-5 py-5 flex flex-col">
            <div class="flex items-center gap-0.5 mb-3">{Array.from({length:5}).map(()=><svg width="13" height="13" viewBox="0 0 12 12" fill="#F5A623" aria-hidden="true"><path d="M6 1l1.236 2.505L10 3.82l-2 1.948.472 2.752L6 7.25l-2.472 1.27L4 5.768 2 3.82l2.764-.315z"/></svg>)}</div>
            <p class="text-[15px] font-normal text-foreground leading-[1.65] flex-1">As a part of BNI I get to connect with Patrick each week and see the care and attention that Built Clough Construction puts into every project and every client relationship. Highly recommend.</p>
            <div class="flex items-center gap-3 mt-5 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full border border-border bg-[#f0ece8] dark:bg-[#2a2a2a] flex items-center justify-center flex-shrink-0"><span class="text-[11px] font-medium text-[#6b6b6b]">NS</span></div>
              <div><p class="text-[13px] font-medium text-foreground">Nic S.</p><p class="text-[12px] font-normal text-[#999]">Southern Illinois · 2025</p></div>
            </div>
          </div>
        </div>

        <!-- Column 2 — center, longest card first -->
        <div class="flex flex-col gap-4">
          <div class="bg-white dark:bg-[#1f1f1f] border border-border rounded-[12px] flex flex-col">
